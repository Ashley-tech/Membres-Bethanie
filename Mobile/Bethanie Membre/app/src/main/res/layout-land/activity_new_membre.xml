<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        android:gravity="center_horizontal"
        android:text="EGLISE PROTESTANTE UNIE DE FRANCE \nGestion des membres"
        android:textColor="@color/red"
        android:textSize="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/new_membre_intro"/>

    <TextView
        android:id="@+id/new_membre_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nouveau membre"
        android:textSize="20dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@+id/spinnerSexe"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerSexe"
        android:layout_width="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="61dp"
        android:entries="@array/sexe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/new_membre_intro"
        app:layout_constraintEnd_toStartOf="@id/editTextPersonLN"
        app:layout_constraintBottom_toTopOf="@id/editTextNaissance"/>

    <EditText
        android:id="@+id/editTextPersonLN"
        android:layout_width="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPersonName"
        android:hint="Nom* :"
        app:layout_constraintStart_toEndOf="@id/spinnerSexe"
        app:layout_constraintEnd_toStartOf="@id/editTextPersonFN"
        app:layout_constraintTop_toBottomOf="@id/new_membre_intro"
        app:layout_constraintBottom_toTopOf="@id/editTextNaissance"/>

    <EditText
        android:id="@+id/editTextPersonFN"
        android:layout_width="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPersonName"
        android:hint="Prénom* :"
        app:layout_constraintTop_toBottomOf="@id/new_membre_intro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/editTextPersonLN"
        app:layout_constraintBottom_toTopOf="@id/editTextEmailAddress"/>

    <EditText
        android:id="@+id/editTextNaissance"
        android:layout_width="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Date de naissance* : (Format AAAA-MM-DD)"
        android:inputType="textPersonName"
        app:layout_constraintEnd_toStartOf="@id/editTextEmailAddress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editTextPersonLN"
        app:layout_constraintBottom_toTopOf="@id/buttonaddmembre"/>

    <EditText
        android:id="@+id/editTextEmailAddress"
        android:layout_width="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="E-mail* :"
        android:inputType="textEmailAddress"
        app:layout_constraintBottom_toTopOf="@id/buttonretournewmembre"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/editTextNaissance"
        app:layout_constraintTop_toBottomOf="@id/editTextPersonFN"/>

    <Button
        android:id="@+id/buttonaddmembre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ajouter ce membre"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="4dp"
        app:layout_constraintEnd_toStartOf="@id/buttonretournewmembre"
        app:layout_constraintTop_toBottomOf="@id/editTextNaissance"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/buttonretournewmembre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="4dp"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        app:layout_constraintTop_toBottomOf="@id/editTextEmailAddress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/buttonaddmembre"/>
</androidx.constraintlayout.widget.ConstraintLayout>