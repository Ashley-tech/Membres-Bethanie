<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="EGLISE PROTESTANTE UNIE DE FRANCE \nGestion des membres"
        android:textColor="@color/red"
        android:textSize="30dp"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/info_account_inscrit_intro" />

    <TextView
        android:id="@+id/info_account_inscrit_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plus d'informations sur "
        android:textStyle="bold"
        android:textSize="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@id/info_contact"
        android:gravity="center_horizontal"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/info_classique"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Date de naissance : \nAdresse e-mail :"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/info_contact"
        app:layout_constraintTop_toBottomOf="@id/info_account_inscrit_intro"
        android:layout_marginLeft="6dp"
        android:layout_marginRight="6dp"
        app:layout_constraintBottom_toTopOf="@id/liens"/>

    <TextView
        android:id="@+id/info_contact"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="6dp"
        android:layout_marginLeft="6dp"
        android:text="Téléphone portable personnel : \nTéléphone fixe personnel : \nTéléphone fax personnel : \nTéléphone portable professionnel : \nTéléphone fixe professionnel : \nTéléphone fax professionnel : "
        app:layout_constraintStart_toEndOf="@id/info_classique"
        app:layout_constraintEnd_toStartOf="@id/info_localisation"
        app:layout_constraintTop_toBottomOf="@id/info_account_inscrit_intro"
        app:layout_constraintBottom_toTopOf="@id/liens"/>

    <TextView
        android:id="@+id/info_localisation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Adresse : \nComplément d'adresse : \nCode postal : \nVille : \nNuméro de boîte ou d'appartement : "
        android:layout_marginRight="6dp"
        android:layout_marginLeft="6dp"
        app:layout_constraintTop_toBottomOf="@id/info_account_inscrit_intro"
        app:layout_constraintBottom_toTopOf="@id/liens"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/info_contact"/>

    <TextView
        android:id="@+id/liens"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Liens : "
        android:gravity="center_horizontal"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_contact"
        app:layout_constraintBottom_toTopOf="@id/buttonModifierContact"/>

    <Button
        android:id="@+id/buttonModifier"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Modifier les coordonnées classique"
        android:textColor="@color/blue"
        android:backgroundTint="@color/yellow"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="4dp"
        app:layout_constraintTop_toBottomOf="@id/liens"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/buttonModifierContact"
        app:layout_constraintBottom_toTopOf="@id/buttonModifierLien"/>

    <Button
        android:id="@+id/buttonModifierContact"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Modifier les coordonnées de contact"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        app:layout_constraintTop_toBottomOf="@id/liens"
        app:layout_constraintEnd_toStartOf="@id/buttonModifierLocal"
        app:layout_constraintStart_toEndOf="@id/buttonModifier"
        app:layout_constraintBottom_toTopOf="@id/buttonDesinscrireMembre"/>

    <Button
        android:id="@+id/buttonModifierLocal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Modifier les coordonnées de localisation"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        app:layout_constraintTop_toBottomOf="@id/liens"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/buttonModifierContact"
        app:layout_constraintBottom_toTopOf="@id/buttonretourinfoa"/>

    <Button
        android:id="@+id/buttonModifierLien"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Modifier les liens"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonModifier"
        app:layout_constraintEnd_toStartOf="@id/buttonDesinscrireMembre"/>

    <Button
        android:id="@+id/buttonDesinscrireMembre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Désinscrire ce membre"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonModifierContact"
        app:layout_constraintStart_toEndOf="@id/buttonModifierLien"
        app:layout_constraintEnd_toStartOf="@id/buttonretourinfoa"/>

    <Button
        android:id="@+id/buttonretourinfoa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonModifierLocal"
        app:layout_constraintStart_toEndOf="@id/buttonDesinscrireMembre"/>
</androidx.constraintlayout.widget.ConstraintLayout>