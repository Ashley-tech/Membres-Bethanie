<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="EGLISE PROTESTANTE UNIE DE FRANCE \nGestion des membres"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/voc_list"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="@color/red"
        android:textSize="40dp"
        android:layout_marginLeft="6dp"
        android:layout_marginRight="6dp"
        android:gravity="center_horizontal"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/voc_intro"/>

    <TextView
        android:id="@+id/voc_intro"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Glossaire des liens"
        android:gravity="center_horizontal"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textSize="20dp"
        app:layout_constraintEnd_toStartOf="@id/voc_list"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@id/buttonretourvocliens"/>

    <ListView
        android:id="@+id/voc_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginStart="13dp"
        android:layout_marginLeft="13dp"
        android:layout_marginTop="13dp"
        android:layout_marginEnd="13dp"
        android:layout_marginRight="13dp"
        android:layout_marginBottom="13dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/voc_intro">

    </ListView>

    <Button
        android:id="@+id/buttonretourvocliens"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/voc_list"
        app:layout_constraintTop_toBottomOf="@id/voc_intro"/>
</androidx.constraintlayout.widget.ConstraintLayout>