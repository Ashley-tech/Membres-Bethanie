<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ConfirmDeleteMembreActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EGLISE PROTESTANTE UNIE DE FRANCE \nGestion des membres"
        android:textColor="@color/red"
        android:textSize="40dp"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center_horizontal"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/delete_membre_text"
        tools:layout_editor_absoluteX="180dp"
        tools:layout_editor_absoluteY="114dp" />

    <TextView
        android:id="@+id/delete_membre_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20dp"
        android:gravity="center_horizontal"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="TextView"
        app:layout_constraintBottom_toTopOf="@+id/buttonDeleteMembre"
        tools:layout_editor_absoluteX="169dp" />

    <Button
        android:id="@+id/buttonDeleteMembre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="4dp"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:text="Oui"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/buttonDeleteMembreNo"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteY="679dp" />

    <Button
        android:id="@+id/buttonDeleteMembreNo"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="4dp"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Non"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/buttonDeleteMembre" />
</androidx.constraintlayout.widget.ConstraintLayout>