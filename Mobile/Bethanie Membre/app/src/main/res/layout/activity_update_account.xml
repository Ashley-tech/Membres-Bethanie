<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UpdateAccountActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EGLISE PROTESTANTE UNIE DE FRANCE \nGestion des membres"
        android:layout_marginRight="7dp"
        android:layout_marginLeft="7dp"
        android:textSize="40dp"
        android:textColor="@color/red"
        android:gravity="center_horizontal"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@+id/update_account_intro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/update_account_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:text="Modification des informations de votre compte"
        android:gravity="center_horizontal"
        android:textAlignment="center"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@+id/editTextLogin_0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/editTextLogin_0"
        android:layout_width="0dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPersonName"
        android:hint="Login *:"
        app:layout_constraintBottom_toTopOf="@+id/editTextPassword_0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/update_account_intro"/>

    <EditText
        android:id="@+id/editTextPassword_0"
        android:layout_width="0dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/editTextLogin_0"
        android:hint="Nouveau mot de passe *:"
        app:layout_constraintBottom_toTopOf="@+id/editTextPassword2_0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/editTextPassword2_0"
        android:layout_width="0dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPassword"
        android:hint="Reconfirmation du mot de passe *:"
        app:layout_constraintTop_toBottomOf="@id/editTextPassword_0"
        app:layout_constraintBottom_toTopOf="@+id/Profil_Type_0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/Profil_Type_0"
        android:layout_width="0dp"
        android:layout_marginLeft="17dp"
        android:layout_marginRight="17dp"
        android:layout_height="56dp"
        android:entries="@array/type_profil"
        app:layout_constraintTop_toBottomOf="@id/editTextPassword2_0"
        app:layout_constraintBottom_toTopOf="@+id/buttonUpdateAccount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/buttonUpdateAccount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Valider les modifications"
        app:layout_constraintBottom_toTopOf="@+id/buttonretourUpdateAccount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Profil_Type_0"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"/>

    <Button
        android:id="@+id/buttonretourUpdateAccount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Retour"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonUpdateAccount"
        android:backgroundTint="@color/yellow"
        android:textColor="@color/blue"/>
</androidx.constraintlayout.widget.ConstraintLayout>